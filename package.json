{
  "name": "tinker",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first AI workspace. Your vault, your LLM, your rules.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./apps/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" --filter \"./apps/*\" typecheck",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test",
    "dev:desktop": "pnpm --filter @tinker/desktop dev",
    "dev:web": "pnpm --filter @tinker/desktop dev:web",
    "dev:design": "pnpm --filter @tinker/desktop dev:design",
    "clean": "pnpm -r exec rm -rf dist out target src-tauri/target .turbo node_modules && rm -rf node_modules"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.4.3",
    "opencode-ai": "^1.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^20.11.30",
    "eslint": "^9.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.29.0"
  }
}
