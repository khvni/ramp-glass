{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability set for the main Tinker window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "sql:default",
    "keyring:default",
    "allow-get-opencode-url",
    "allow-oauth-flow",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive"
  ]
}
