{
  "$schema": "https://opencode.ai/schema/opencode.json",
  "mcp": {
    "gmail": {
      "type": "local",
      "command": ["npx", "-y", "@google/gmail-mcp-server"],
      "enabled": false
    },
    "google-calendar": {
      "type": "local",
      "command": ["npx", "-y", "@google/calendar-mcp-server"],
      "enabled": false
    },
    "google-drive": {
      "type": "local",
      "command": ["npx", "-y", "@google/drive-mcp-server"],
      "enabled": false
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "@tacticlaunch/mcp-linear"],
      "enabled": false,
      "environment": {
        "LINEAR_API_KEY": "{env:LINEAR_API_KEY}"
      }
    }
  }
}
